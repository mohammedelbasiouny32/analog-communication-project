        bb_out_C  = bb_out_C / (max(abs(bb_out_C)) + eps);
        bb_outs_C{station_idx, oi} = bb_out_C;

        % Time domain figure
        figure('Name', sprintf('Fig C-S%d-O%d-T – Station %d %s: Time Domain', ...
