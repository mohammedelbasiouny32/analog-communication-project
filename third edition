
%  Analog Modulation Communication Project – 2026
% =========================================================================

clear; close all; clc;

% -------------------------------------------------------------------------
%  SYSTEM PARAMETERS
% -------------------------------------------------------------------------
FIRST_CARRIER_FREQ  = 100e3;
CARRIER_SPACING     = 30e3;
IF_FREQ             = 15e3;
UPSAMPLE_FACTOR     = 10;
FILTER_ORDER        = 6;
PLOT_DURATION_MS    = 5;

% -------------------------------------------------------------------------
%  SECTION 1 – LOAD AUDIO SIGNALS
% -------------------------------------------------------------------------
fprintf('=== SECTION 1: Loading Audio Signals ===\n');

audio_file_list = {'signal1.wav', 'signal2.wav'};
num_stations    = numel(audio_file_list);

raw_mono_signals      = cell(num_stations, 1);
original_sample_rates = zeros(num_stations, 1);

for station_idx = 1 : num_stations
    filename = audio_file_list{station_idx};
    if isfile(filename)
        [audio_data, sample_rate] = audioread(filename);
        fprintf('  Loaded "%s"  |  Fs = %d Hz\n', filename, sample_rate);
        if size(audio_data, 2) == 2
            mono_signal = audio_data(:,1) + audio_data(:,2);
        else
            mono_signal = audio_data(:,1);
        end
    else
        fprintf('  "%s" not found – using synthetic test signal.\n', filename);
        sample_rate = 8000;
        duration    = 2;
        tv          = (0 : 1/sample_rate : duration - 1/sample_rate)';
        f1 = 400  + (station_idx-1)*1800;
        f2 = 1200 + (station_idx-1)*1800;
        mono_signal = 0.6*sin(2*pi*f1*tv) + 0.4*sin(2*pi*f2*tv);
    end
    mono_signal = mono_signal / (max(abs(mono_signal)) + eps);
    raw_mono_signals{station_idx}      = mono_signal;
    original_sample_rates(station_idx) = sample_rate;
end

base_sample_rate  = original_sample_rates(1);
max_signal_length = max(cellfun(@numel, raw_mono_signals));

for station_idx = 1 : num_stations
    len = numel(raw_mono_signals{station_idx});
    if len < max_signal_length
        raw_mono_signals{station_idx} = ...
            [raw_mono_signals{station_idx}; zeros(max_signal_length - len, 1)];
    end
end

% -------------------------------------------------------------------------
%  SECTION 2 – UPSAMPLE
% -------------------------------------------------------------------------
fprintf('\n=== SECTION 2: Upsampling (x%d) ===\n', UPSAMPLE_FACTOR);

Fs = base_sample_rate * UPSAMPLE_FACTOR;
Ts = 1 / Fs;

upsampled_signals = cell(num_stations, 1);
for station_idx = 1 : num_stations
    upsampled_signals{station_idx} = interp(raw_mono_signals{station_idx}, UPSAMPLE_FACTOR);
end

N = numel(upsampled_signals{1});
t = (0 : N-1)' * Ts;

% -------------------------------------------------------------------------
%  BANDWIDTH CALCULATION – ALL STATIONS
% -------------------------------------------------------------------------
fprintf('\n=== BANDWIDTH ANALYSIS: All Stations ===\n');
fprintf('  %-10s %-20s %-20s %-20s\n', 'Station', 'Msg BW (kHz)', 'RF BW (kHz)', 'Carrier (kHz)');
fprintf('  %s\n', repmat('-', 1, 72));

message_bandwidths = zeros(num_stations, 1);
rf_bandwidths      = zeros(num_stations, 1);
carrier_freq_list  = zeros(num_stations, 1);

for station_idx = 1 : num_stations
    msg_bw = estimate_bandwidth_99pct(upsampled_signals{station_idx}, Fs);
    rf_bw  = 2 * msg_bw;
    Fc_n   = FIRST_CARRIER_FREQ + (station_idx - 1) * CARRIER_SPACING;
    message_bandwidths(station_idx) = msg_bw;
    rf_bandwidths(station_idx)      = rf_bw;
    carrier_freq_list(station_idx)  = Fc_n;
    fprintf('  %-10d %-20.3f %-20.3f %-20.1f\n', ...
        station_idx, msg_bw/1e3, rf_bw/1e3, Fc_n/1e3);
end

% Use Station 1 bandwidth as the common reference for shared filters
message_bandwidth = message_bandwidths(1);
rf_bandwidth      = rf_bandwidths(1);
fprintf('\n  Reference message BW (Station 1) = %.3f kHz\n', message_bandwidth/1e3);
fprintf('  Reference RF BW      (Station 1) = %.3f kHz\n', rf_bandwidth/1e3);
fprintf('  Effective Fs                      = %.1f kHz\n', Fs/1e3);

% -------------------------------------------------------------------------
%  SECTION 3 – DSB-SC MODULATION & FDM
% -------------------------------------------------------------------------
fprintf('\n=== SECTION 3: Modulation & FDM ===\n');

modulated_matrix = zeros(N, num_stations);
for station_idx = 1 : num_stations
    carrier_sig = cos(2*pi*carrier_freq_list(station_idx)*t);
    modulated_matrix(:, station_idx) = upsampled_signals{station_idx} .* carrier_sig;
    fprintf('  Station %d: Carrier = %.1f kHz  |  Msg BW = %.3f kHz  |  RF BW = %.3f kHz\n', ...
        station_idx, carrier_freq_list(station_idx)/1e3, ...
        message_bandwidths(station_idx)/1e3, rf_bandwidths(station_idx)/1e3);
end

fdm_signal = sum(modulated_matrix, 2);

if_carrier = cos(2*pi*IF_FREQ*t);

% =========================================================================
%  FIGURE 1 – BASEBAND SIGNAL SPECTRA (all stations)
% =========================================================================
figure('Name','Fig 1 – Baseband Spectra','NumberTitle','off','Color','w');
for s = 1:num_stations
    subplot(num_stations,1,s);
    plot_spectrum(upsampled_signals{s}, Fs, ...
        sprintf('Station %d Baseband Spectrum  |  Msg BW = %.3f kHz', ...
                s, message_bandwidths(s)/1e3), 'blue');
end
sgtitle('Baseband Audio Signal Spectra – All Stations', ...
        'FontSize',13,'FontWeight','bold');

% =========================================================================
%  FIGURE 2 – TRANSMITTED FDM SIGNAL
% =========================================================================
figure('Name','Fig 2 – Transmitted FDM Signal','NumberTitle','off','Color','w');
subplot(2,1,1);
plot_time(fdm_signal, t, PLOT_DURATION_MS, ...
    'Transmitted FDM Signal – Time Domain', [0.8 0.2 0]);
subplot(2,1,2);
plot_spectrum(fdm_signal, Fs, ...
    'Transmitted FDM Signal – Spectrum (All Stations)', [0.8 0.2 0]);
sgtitle('Transmitted FDM Signal','FontSize',13,'FontWeight','bold');

% =========================================================================
%  CASE A – NORMAL RECEPTION (WITH RF BPF) – BOTH STATIONS
% =========================================================================
fprintf('\n=== CASE A: Normal Reception (WITH RF BPF) – Both Stations ===\n');

bb_outs_A = cell(num_stations, 1);

for station_idx = 1 : num_stations
    target_Fc   = carrier_freq_list(station_idx);
    F_osc       = target_Fc + IF_FREQ;
    local_osc_s = cos(2*pi*F_osc*t);

    fprintf('\n  --- Station %d | Carrier = %.1f kHz | LO = %.1f kHz ---\n', ...
            station_idx, target_Fc/1e3, F_osc/1e3);

    rf_out_A  = apply_BPF(fdm_signal, target_Fc, rf_bandwidth, Fs, FILTER_ORDER);
    mix_out_A = rf_out_A .* local_osc_s;
    if_out_A  = apply_BPF(mix_out_A, IF_FREQ, rf_bandwidth, Fs, FILTER_ORDER);
    bb_mix_A  = if_out_A .* if_carrier;
    bb_out_A  = apply_LPF(bb_mix_A, message_bandwidth, Fs, FILTER_ORDER);
    bb_out_A  = bb_out_A / (max(abs(bb_out_A)) + eps);
    bb_outs_A{station_idx} = bb_out_A;

    % Time domain figure
    figure('Name', sprintf('Fig A%d-T – Case A Station %d: Time Domain', station_idx, station_idx), ...
           'NumberTitle','off','Color','w');
    subplot(5,1,1); plot_time(fdm_signal, t, PLOT_DURATION_MS, ...
        'Stage 0 – Transmitted FDM Signal', [0.8 0.2 0]);
    subplot(5,1,2); plot_time(rf_out_A, t, PLOT_DURATION_MS, ...
        sprintf('Stage 1 – RF BPF (centred %.1f kHz)', target_Fc/1e3), [0 0.6 0]);
    subplot(5,1,3); plot_time(mix_out_A, t, PLOT_DURATION_MS, ...
        'Stage 2 – After Mixer', [0.6 0 0.6]);
    subplot(5,1,4); plot_time(if_out_A, t, PLOT_DURATION_MS, ...
        sprintf('Stage 3 – IF BPF (centred %.1f kHz)', IF_FREQ/1e3), [0.9 0.5 0]);
    subplot(5,1,5); plot_time(bb_out_A, t, PLOT_DURATION_MS, ...
        'Stage 4 – Recovered Signal (Baseband LPF)', [0 0.3 0.9]);
    sgtitle(sprintf('CASE A – WITH RF BPF | Station %d (%.1f kHz): Time Domain', ...
                    station_idx, target_Fc/1e3), 'FontSize',13,'FontWeight','bold');

    % Spectrum figure
    figure('Name', sprintf('Fig A%d-S – Case A Station %d: Spectrum', station_idx, station_idx), ...
           'NumberTitle','off','Color','w');
    subplot(5,1,1); plot_spectrum(fdm_signal, Fs, 'Stage 0 – FDM Spectrum', [0.8 0.2 0]);
    subplot(5,1,2); plot_spectrum(rf_out_A, Fs, ...
        sprintf('Stage 1 – RF BPF Output (centred %.1f kHz)', target_Fc/1e3), [0 0.6 0]);
    subplot(5,1,3); plot_spectrum(mix_out_A, Fs, 'Stage 2 – Mixer Output', [0.6 0 0.6]);
    subplot(5,1,4); plot_spectrum(if_out_A, Fs, ...
        sprintf('Stage 3 – IF BPF Output (centred %.1f kHz)', IF_FREQ/1e3), [0.9 0.5 0]);
    subplot(5,1,5); plot_spectrum(bb_out_A, Fs, 'Stage 4 – Recovered Message', [0 0.3 0.9]);
    sgtitle(sprintf('CASE A – WITH RF BPF | Station %d (%.1f kHz): Spectrum', ...
                    station_idx, target_Fc/1e3), 'FontSize',13,'FontWeight','bold');

    fprintf('  Playing audio – Case A, Station %d (WITH RF BPF)...\n', station_idx);
    audio_out = decimate(bb_out_A, UPSAMPLE_FACTOR, 'fir');
    audio_out = audio_out / (max(abs(audio_out)) + eps);
    sound(audio_out, base_sample_rate);
    pause(numel(audio_out)/base_sample_rate + 0.5);
end

