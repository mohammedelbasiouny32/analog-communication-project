            sprintf('Stage 2 – After Mixer (LO offset = +%.1f kHz)', delta_f/1e3), clr);
        subplot(5,1,4); plot_time(if_out_C, t, PLOT_DURATION_MS, ...
            'Stage 3 – IF BPF Output', [0.9 0.5 0]);
        subplot(5,1,5); plot_time(bb_out_C, t, PLOT_DURATION_MS, ...
