subplot(4,1,1);
plot_time(bb_out_A, t, PLOT_DURATION_MS, ...
    'Case A – WITH RF BPF (clean recovery)', [0 0.6 0]);
subplot(4,1,2);
plot_time(bb_out_B, t, PLOT_DURATION_MS, ...
    'Case B – WITHOUT RF BPF (image interference)', [0.9 0 0]);
subplot(4,1,3);
plot_time(bb_outs_C{1}, t, PLOT_DURATION_MS, ...
    'Case C1 – Oscillator +0.1 kHz offset', [0 0.45 0.8]);
subplot(4,1,4);
plot_time(bb_outs_C{2}, t, PLOT_DURATION_MS, ...
    'Case C2 – Oscillator +1 kHz offset', [0.8 0.3 0]);

sgtitle('All Cases – Final Baseband Output: Time Domain Comparison', ...
        'FontSize',13,'FontWeight','bold');

figure('Name','Fig 12 – Final Output: Spectrum Comparison (All Cases)', ...
       'NumberTitle','off','Color','w');

subplot(4,1,1);
plot_spectrum(bb_out_A, Fs, 'Case A – WITH RF BPF (clean)', [0 0.6 0]);
subplot(4,1,2);
plot_spectrum(bb_out_B, Fs, 'Case B – WITHOUT RF BPF (image interference)', [0.9 0 0]);
subplot(4,1,3);
plot_spectrum(bb_outs_C{1}, Fs, ...
    'Case C1 – Oscillator +0.1 kHz (slight spectral shift)', [0 0.45 0.8]);
subplot(4,1,4);
plot_spectrum(bb_outs_C{2}, Fs, ...
    'Case C2 – Oscillator +1 kHz (noticeable spectral shift)', [0.8 0.3 0]);

sgtitle('All Cases – Final Baseband Output: Spectrum Comparison', ...
        'FontSize',13,'FontWeight','bold');

fprintf('\n=== Simulation Complete – All Figures Generated ===\n');

% =========================================================================
%  HELPER FUNCTIONS
% =========================================================================

function plot_time(signal, t, duration_ms, title_str, color)
% PLOT_TIME  Plot the first <duration_ms> milliseconds of a signal.
    n_show = find(t >= duration_ms*1e-3, 1, 'first');
    if isempty(n_show); n_show = numel(t); end
    plot(t(1:n_show)*1e3, signal(1:n_show), 'Color', color, 'LineWidth', 1.2);
    title(title_str, 'FontSize', 10, 'FontWeight', 'bold');
    xlabel('Time (ms)', 'FontSize', 9);
    ylabel('Amplitude',  'FontSize', 9);
    xlim([0, t(n_show)*1e3]);
    grid on;
end

function plot_spectrum(signal, Fs, title_str, color)
% PLOT_SPECTRUM  Double-sided normalised amplitude spectrum.
    N    = numel(signal);
    f    = (-N/2 : N/2-1) * (Fs/N);
    S    = abs(fftshift(fft(signal))) / N;
    plot(f/1e3, S, 'Color', color, 'LineWidth', 1.2);
    title(title_str, 'FontSize', 10, 'FontWeight', 'bold');
    xlabel('Frequency (kHz)', 'FontSize', 9);
    ylabel('|X(f)|',          'FontSize', 9);
    xlim([-Fs/2/1e3, Fs/2/1e3]);
    grid on;
end

function y = apply_BPF(x, Fc, BW, Fs, order)
    Wn    = [(Fc - BW/2), (Fc + BW/2)] / (Fs/2);
    Wn    = max(min(Wn, 1-1e-4), 1e-4);
    [b,a] = butter(order, Wn, 'bandpass');
    y     = filtfilt(b, a, x);
end

function y = apply_LPF(x, Fc, Fs, order)
    Wn    = min(Fc/(Fs/2), 1-1e-4);
    [b,a] = butter(order, Wn, 'low');
    y     = filtfilt(b, a, x);
end

function BW = estimate_bandwidth_99pct(signal, Fs)
    N    = numel(signal);
    P    = abs(fft(signal)).^2;
    P    = P(1:floor(N/2));
    cP   = cumsum(P);
    idx  = find(cP >= 0.99*sum(P), 1, 'first');
    BW   = idx * (Fs/N) * 1.15;
end
